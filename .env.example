# Copy this file to .env and fill in the values before deploying.
# .env is gitignored — never commit it.

# PostgreSQL credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=hustle

# Seeded facilitator account (created on first startup if it doesn't exist)
# Change these before going live — the facilitator uses them to log in at /register
FACILITATOR_PHONE=0000000001
FACILITATOR_PASSWORD=Hustle@2026

# Copy this file to .env and fill in the values before deploying.
# .env is gitignored — never commit it.

# PostgreSQL credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=hustle

# ── Staff accounts (seeded on first startup if they don't exist) ──────────────
# Change these before going live. All staff log in at /register (login tab).

# Facilitator — can review applications, run the pipeline, view operations
FACILITATOR_PHONE=0000000001
FACILITATOR_PASSWORD=Hustle@2026

# Coordinator — full access: all facilitator permissions + coordinator dashboard
COORDINATOR_PHONE=0000000002
COORDINATOR_PASSWORD=Hustle@2026

# Operations (FUTURE — role not yet implemented in backend)
# OPERATIONS_PHONE=0000000003
# OPERATIONS_PASSWORD=Hustle@2026

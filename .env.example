# Copy this file to .env and fill in the values before deploying.
# .env is gitignored — never commit it.

# PostgreSQL credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=hustle

# Staff account — seeded on first startup if it doesn't exist.
# Role: COORDINATOR (gives access to all tabs: Facilitator, Coordinator, Operations).
# Log in at any tab's sign-in form using these credentials.
# Add individual facilitator / coordinator accounts via the app when you go live.
STAFF_PHONE=your-phone-number
STAFF_PASSWORD=change-me-strong-password
